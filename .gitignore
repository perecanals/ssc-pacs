/maintenance/

# Ingestion protocol logs
stanford-stroke-pacs/image_ingestion_protocols/logs/

# SQL data dumps (schema only — CSV/raw data stays out)
ssc-sql-db/tables/
# Editor SQL scratch sessions at the repo root (DDL under ssc-sql-db/ is tracked)
/*.session.sql

# OS
.DS_Store
Thumbs.db

# Embedded upstream VCS metadata (orthanc-indexer-patched vendors Mercurial source)
.hg/
**/.hg/

# Deprecated compose auto-merge override. macOS deltas now live in the tracked
# docker-compose.override.macos.yml, selected explicitly by scripts/orthanc/dc.sh.
# Ignore the auto-merge name so a stray copy never silently breaks a Linux host.
docker-compose.override.yml
**/docker-compose.override.yml

# Per-host deployment identity overrides for the unit installers (auto-derived
# by default; see deploy.env.example).
deploy.env
**/deploy.env

# Site/run-specific ingestion config (use the .example.yaml template)
stanford-stroke-pacs/image_ingestion_protocols/execute_image_ingestion_protocol.yaml
# Per-batch configs derived from the base YAML by run_all_batches.sh
stanford-stroke-pacs/image_ingestion_protocols/batch_configs/
