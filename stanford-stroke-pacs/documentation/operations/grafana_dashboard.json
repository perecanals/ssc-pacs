{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping ssc-companion :8043/metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"ssc-companion\"}[5m])) by (path_template)",
          "legendFormat": "{{ path_template }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency p50 / p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"ssc-companion\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"ssc-companion\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Warm / Evict Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(cold_storage_warm_total{result=\"success\",job=\"ssc-companion\"}[15m])) / clamp_min(sum(rate(cold_storage_warm_total{job=\"ssc-companion\"}[15m])), 1e-10)",
          "legendFormat": "warm success rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cold_storage_evict_total{result=\"success\",job=\"ssc-companion\"}[15m])) / clamp_min(sum(rate(cold_storage_evict_total{job=\"ssc-companion\"}[15m])), 1e-10)",
          "legendFormat": "evict success rate",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Cold-Storage Disk Free",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cold_storage_disk_free_bytes{job=\"ssc-companion\"}",
          "legendFormat": "free bytes",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Warming Rows (stuck-warm indicator)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cold_storage_warming_rows{job=\"ssc-companion\"}",
          "legendFormat": "warming rows",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ssc-companion", "pacs"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "SSC Companion",
  "uid": "ssc-companion-starter",
  "version": 1
}
