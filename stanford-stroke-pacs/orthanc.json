{
  "Name": "Stanford Stroke Center PACS",
  "StorageDirectory": "/var/lib/orthanc/db",
  "IndexDirectory": "/var/lib/orthanc/db",
  "StorageCompression": false,
  "HttpServerEnabled": true,
  "HttpPort": 8042,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": true,
  "DicomServerEnabled": true,
  "DicomPort": 4242,
  "DicomAet": "SSC",
  "_comment_StableAge": "Seconds of inactivity before a series is 'stable'. The DICOMweb plugin builds its series metadata cache on that event, by reading the DICOM files - and ingestion must not delete a series' loose files until it has. Lowered from Orthanc's 60s default so that wait is short.",
  "StableAge": 10,
  "Indexer": {
    "Enable": true,
    "Folders": [],
    "Interval": 60,
    "RemoveMissingFiles": false,
    "ScanRoots": [
      "/dicom-data"
    ]
  },
  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/"
  },
  "Ohif": {
    "RouterBasename": "/ohif",
    "DataSource": "dicom-web"
  },
  "OrthancExplorer2": {
    "Enable": true,
    "IsDefaultOrthancUI": true,
    "UiOptions": {
      "EnableEditLabels": true,
      "EnableLabelsCount": true,
      "EnableStudyList": true,
      "StudyListColumns": [
        "PatientID",
        "PatientName",
        "StudyDate",
        "AccessionNumber",
        "StudyDescription",
        "modalities",
        "seriesCount"
      ],
      "EnableOpenInOhifViewer3": true,
      "OhifViewer3PublicRoot": "/ohif/"
    }
  }
}
