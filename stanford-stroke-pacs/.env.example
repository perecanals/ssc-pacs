# Copy to `.env` and fill in secrets only.
# docker-compose loads `env_file` from the path in docker-compose.yml — keep variables in sync.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=stanford-stroke
DB_USER=
DB_PASSWORD=

PG_ORTHANC_DB=orthanc_db
PG_ORTHANC_USER=
PG_ORTHANC_PASSWORD=

ORTHANC_URL=http://localhost:8042
ORTHANC_ADMIN_USER=admin
ORTHANC_ADMIN_PASSWORD=

JWT_SECRET=

# Non-secret paths, storage mode, and session length live in `config.toml` at the repo root.
