# Copy to `.env` and fill in secrets only.
# docker-compose loads `env_file` from the path in docker-compose.yml — keep variables in sync.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=stanford-stroke
DB_USER=
DB_PASSWORD=

PG_ORTHANC_DB=orthanc_db
PG_ORTHANC_USER=
PG_ORTHANC_PASSWORD=

ORTHANC_URL=http://localhost:8042
ORTHANC_ADMIN_USER=admin
ORTHANC_ADMIN_PASSWORD=

JWT_SECRET=

# Orthanc ports. Optional — default to 8042 (HTTP) / 4242 (DICOM) if unset.
# Set here to change them in ONE place: docker-compose passes them to the
# container (ORTHANC__HTTP_PORT/ORTHANC__DICOM_PORT) and publishes the same
# ports on macOS. orthanc.json carries the in-image defaults.
#ORTHANC_HTTP_PORT=8042
#ORTHANC_DICOM_PORT=4242

# Non-secret paths, storage mode, and session length live in `config.toml` at the repo root.
# Per-host service-unit identity (user/paths) lives in `deploy.env` — see deploy.env.example.
